# Database
DATABASE_URL="postgresql://usuario:senha@localhost:5432/olhosdegato?schema=public"

# JWT
JWT_SECRET="gere-uma-chave-secreta-forte-aqui"
JWT_EXPIRES_IN="7d"

# Server
PORT=3333
NODE_ENV="development"

# Mail (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
MAIL_FROM="noreply@olhosdegato.com"

# CORS (em produção, colocar o domínio do frontend)
CORS_ORIGIN="http://localhost:3000"

# Storage (S3/Cloudflare R2) — usar "local" para desenvolvimento
STORAGE_PROVIDER="local"
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# Mercado Livre (criar app em https://developers.mercadolivre.com.br)
ML_APP_ID=""
ML_CLIENT_SECRET=""
ML_REDIRECT_URI="http://localhost:3333/api/v1/admin/marketplace/accounts/MERCADO_LIVRE/callback"
